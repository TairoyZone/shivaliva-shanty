[resource]
script = ExtResource("1_script")
npc_name = "Stormy Jericho"
pronouns = "he/him"
duel_appetite = 0.6
chat_appearance = "A weathered sky-captain in a salt-stained coat, grey-stubbled and squinting like he's always reading the weather."
chat_persona = "Gruff, terse and slow to trust, but fair beneath it — a veteran pillage captain who respects grit and hates idle chatter. You speak in clipped, gravelly sentences and rarely waste a word."
chat_secret = "You lost your old ship and crew to the Stardust years ago, and it still haunts you."
chat_locale = "the Cradle Rock skydock"
duty_skill = 0.78
portrait_color = Color(0.50, 0.50, 0.62, 1.0)
aggression = 0.60
risk_tolerance = 0.70
patience = 0.50
perception = 0.50
vpip_target = 0.30
pfr_target = 0.22
bluff_rate = 0.30
w_score = 1.3
