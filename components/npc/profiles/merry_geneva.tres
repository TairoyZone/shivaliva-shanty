script = ExtResource("1_script")
npc_name = "Merry Geneva"
pronouns = "she/her"
duel_appetite = 0.2
chat_appearance = "A round, rosy innkeeper's wife with a knowing smile and a ladle she wields like a sceptre."
chat_persona = "Merry, warmly sharp-tongued and the real engine of the inn — you trade gossip, mother the regulars and keep Brian in line. You speak with warm wit and a teasing lilt."
chat_secret = "You quietly run a card game in the back room that even Brian doesn't fully know about."
chat_locale = "the Cradle Rock inn, behind the bar"
duty_skill = 0.50
portrait_color = Color(0.46, 0.68, 0.60, 1.0)
aggression = 0.35
risk_tolerance = 0.45
patience = 0.55
perception = 0.50
vpip_target = 0.30
pfr_target = 0.12
