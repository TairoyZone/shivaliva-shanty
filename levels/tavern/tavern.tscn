[node name="BrianNpc" parent="YSortNode2D" unique_id=1857623763 instance=ExtResource("6_npc")]
position = Vector2(208, -176)
npc_name = "Hearty Brian"
dialog_lines = Array[String](["Welcome to the Inn, friend — pull up a stool.", "Everyone on Cradle Rock passes through here eventually.", "Hungry? Thirsty? Want to lose some gold at cards? We've got all three."])
portrait_color = Color(0.92, 0.66, 0.3, 1)

[node name="MiaNpc" parent="YSortNode2D" unique_id=1139953103 instance=ExtResource("6_npc")]
position = Vector2(-176, -96)
npc_name = "Spritely Mia"
dialog_lines = Array[String](["Smell that? Tonight's special — and no, you can't have it yet.", "Quick hands, hot pans. That's the whole secret.", "Sit, eat, lose at cards. In that order, ideally."])
portrait_color = Color(0.95, 0.55, 0.65, 1)

[node name="KerrNpc" parent="YSortNode2D" unique_id=643999588 instance=ExtResource("6_npc")]
position = Vector2(-40, 136)
npc_name = "Flint Kerr"
dialog_lines = Array[String](["You here to play, or just to watch?", "I don't bluff. ...Or do I.", "Sit at my table if you think you're quick enough."])
portrait_color = Color(0.78, 0.32, 0.32, 1)

[node name="EllisonNpc" parent="YSortNode2D" unique_id=2641224 instance=ExtResource("6_npc")]
position = Vector2(-40, -232)
npc_name = "Hollow Ellison"
dialog_lines = Array[String](["Every island remembers more than its people do.", "I've forgotten more stories than most folk ever hear.", "Sit by the fire. I'll tell you something true. Mostly true."])
portrait_color = Color(0.62, 0.55, 0.72, 1)

