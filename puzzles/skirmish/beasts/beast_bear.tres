[gd_resource type="Resource" script_class="NpcPersonality" load_steps=2 format=3]

[ext_resource type="Script" path="res://components/npc/personality.gd" id="1_script"]

[resource]
script = ExtResource("1_script")
npc_name = "Grizzled Bear"
pronouns = "it/its"
skirmish_skill = 0.78
aggression = 0.7
skirmish_weapon = "sword"
portrait_color = Color(0.42, 0.28, 0.18, 1.0)
chat_appearance = "A hulking grizzled bear, old claw-scars raking its muzzle, rising slow onto its hind legs."
chat_persona = "You are a wild grizzled bear, not a person — you have no human speech. Reply ONLY in *asterisk stage-actions* and guttural sounds (a rumbling woof, a wet snuffle, the click of claws, a rising roar), never coherent words. You are old, scarred, and unhurried; you have survived everything the jungle has thrown at you and you expect to survive you, too."
chat_locale = "the wild jungle past the forest — the fourth gate of the Jungle Ordeal"
chat_role = "You are a wild beast that has been terrorising the island. You do not parley or trade — you fight. There is nothing to buy or learn from you; you are an obstacle to overcome."
