# Copy to a real environment / host config — NEVER commit the real key.
# Default provider is DeepSeek (cheap, OpenAI-compatible). See README.md for Gemini/Groq/Ollama/Claude.
LLM_API_KEY=sk-your-deepseek-key-here
# Optional (defaults shown):
# LLM_PROVIDER=openai
# LLM_URL=https://api.deepseek.com/chat/completions
# MODEL=deepseek-chat
# TEMPERATURE=0.8
# --- Public-distribution guards (see DEPLOY.md) ---
# SHARED_SECRET=some-long-random-string      # the game must send x-shanty-key
# ADMIN_SECRET=a-different-long-random-string # gates /admin/disable | /admin/enable | /admin/stats
# ALLOWED_ORIGIN=https://your-itch-build-origin
# MAX_TOKENS_CAP=400                          # hard reply-length ceiling
# RATE_LIMIT_RPM=15                           # per-IP requests / minute
# IP_DAILY_CAP=400                            # per-IP requests / UTC day
# DAILY_TOKEN_BUDGET=1500000                  # global tokens / UTC day before chat goes offline
# DISABLED=1                                  # start in the OFF state (re-enable via /admin/enable)
# PORT=8787
